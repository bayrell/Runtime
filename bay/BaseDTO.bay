namespace Runtime;

use Runtime.BaseObject;
use Runtime.SerializeInterface;


class BaseDTO extends BaseObject implements SerializeInterface
{
	/**
	 * Create object
	 */
	void constructor(Map params = null)
	{
		parent();
		this._assign_values(params);
	}
	
	/**
	 * Returns field by name
	 */
	var get(string field_name) => rtl::attr(this, field_name);
	
	
	/**
	 * Set field value
	 */
	void set(string field_name, var value)
	{
		rtl::setAttr(this, field_name, value);
	}
	
	
	/**
	 * Copy object
	 */
	BaseDTO copy() => rtl::copy(this);
	
	
	/**
	 * Returns object data
	 */
	Map data() => rtl::serialize(this);
	
	
	/**
	 * Intersect data
	 */
	Map intersect(Vector items) => this.data().intersect(items);
}
